# Copy to .env (root: scripts/tests) and web/.env.local (the Next app), or set
# these in the Netlify dashboard for deploys. Never commit real values.

# ── Supabase ──────────────────────────────────────────────
# Public (safe to expose to the browser) — used by the web app's auth client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. The service role key bypasses RLS — keep it secret.
# SUPABASE_URL falls back to NEXT_PUBLIC_SUPABASE_URL if unset.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Server-only professional read path. Keep `legacy` until migrations, backfill,
# and shadow parity pass; `shadow` returns legacy results while comparing the
# normalized source. Never prefix this variable with NEXT_PUBLIC_.
PROFESSIONALS_SOURCE=legacy

# ── OpenAI (report generation) ────────────────────────────
OPENAI_API_KEY=
# Optional — overrides the default model (gpt-4o-mini).
OPENAI_MODEL=

# Resume workshop AI critique. Kept separate from report/roadmap generation.
# OPENAI_CRITIQUE_MODEL defaults to gpt-5.6.
OPENAI_CRITIQUE_MODEL=
# Server-enforced successful generations per user per Australia/Sydney day.
RESUME_CRITIQUE_DAILY_LIMIT=25
# Per-kind daily limit for the heavy resume AI generators
# (import / compose / improve / tailor). Defaults to 10.
RESUME_AI_DAILY_LIMIT=10
# Long random server-only secret used to sign two-hour, memory-only critique receipts.
CRITIQUE_RECEIPT_SECRET=

# ── Networking Strategy (Phase 2) ─────────────────────────
# AI drafting + review. Defaults to gpt-5.6.
OPENAI_NETWORKING_MODEL=
# Server-enforced AI drafts + reviews per user per Australia/Sydney day.
NETWORKING_AI_DAILY_LIMIT=25
# Long random server-only secret for OAuth state cookies. Falls back to
# CRITIQUE_RECEIPT_SECRET if unset — set a distinct value in production.
NETWORKING_OAUTH_STATE_SECRET=

# Comma-separated list of providers to enable (e.g. "google,microsoft").
# Leave empty to keep provider connections off; manual send/log always works.
NETWORKING_PROVIDERS_ENABLED=
# Base64-encoded 32-byte AES-256-GCM key for encrypting refresh tokens.
# Generate with: openssl rand -base64 32
NETWORKING_TOKEN_KEY=
NETWORKING_TOKEN_KEY_VERSION=1
# Public site origin, used to build the OAuth redirect URI.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Cloud OAuth app (Gmail send + metadata scopes require Google
# restricted-scope verification before general release — see PHASE_2_PLAN.md).
NETWORKING_GOOGLE_CLIENT_ID=
NETWORKING_GOOGLE_CLIENT_SECRET=

# Microsoft Entra OAuth app.
NETWORKING_MICROSOFT_CLIENT_ID=
NETWORKING_MICROSOFT_CLIENT_SECRET=
NETWORKING_MICROSOFT_TENANT=common
# Shared secret checked against Microsoft Graph change notifications.
NETWORKING_MICROSOFT_CLIENT_STATE=

# ── Data import scripts (root only) ───────────────────────
DATABASE_XLSX_PATH=/path/to/Database_v7_clean.xlsx
