# Copy to .env (root: scripts/tests) and web/.env.local (the Next app), or set
# these in the Netlify dashboard for deploys. Never commit real values.

# ── Supabase ──────────────────────────────────────────────
# Public (safe to expose to the browser) — used by the web app's auth client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. The service role key bypasses RLS — keep it secret.
# SUPABASE_URL falls back to NEXT_PUBLIC_SUPABASE_URL if unset.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI (report generation) ────────────────────────────
OPENAI_API_KEY=
# Optional — overrides the default model (gpt-4o-mini).
OPENAI_MODEL=

# ── Data import scripts (root only) ───────────────────────
DATABASE_XLSX_PATH=/path/to/Database_v7_clean.xlsx
